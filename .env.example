# Moodle
MOODLE_PORT=8080
MOODLE_URL=http://localhost:8080
MOODLE_SITE_NAME=Moodle AI CodeRunner Lab
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=change_me
MOODLE_ADMIN_EMAIL=admin@example.local

# MariaDB
DB_NAME=moodle
DB_USER=moodle
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me

# Local AI: the model is downloaded once into the Ollama volume.
OLLAMA_MODEL=qwen2.5-coder:0.5b
# Timeout and maximum code size used by AI service.
AI_TIMEOUT=60
AI_MAX_CODE_SIZE=20000

# Time zone for all containers.
TZ=Asia/Yekaterinburg
