<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/aicodehelper/db" VERSION="20260713" COMMENT="AI helper request cache">
  <TABLES>
    <TABLE NAME="local_aicodehelper_analysis" COMMENT="Cached AI analyses for CodeRunner question steps">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="attemptid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="slot" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="stepid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="responsejson" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="attemptid_fk" TYPE="foreign" FIELDS="attemptid" REFTABLE="quiz_attempts" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="request_unique" UNIQUE="true" FIELDS="userid, attemptid, slot, stepid"/>
        <INDEX NAME="attempt_lookup" UNIQUE="false" FIELDS="userid, attemptid, slot"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
